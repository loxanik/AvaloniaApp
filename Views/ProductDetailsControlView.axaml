<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Shop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Shop.Views.ProductDetailsControlView"
             x:DataType="vm:ProductDetailsControlViewModel"
             x:Name="RootControl">
    
    <Grid>
        <!-- Основная карточка -->
        <Border Margin="10" 
                Background="White"
                CornerRadius="12">
            <Grid ColumnDefinitions="3*,2*">
                
                <!-- Заголовки -->
                <TextBlock Text="Товар"
                           HorizontalAlignment="Center"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,10"/>
                <TextBlock Grid.Column="1" 
                           Text="Параметры"
                           HorizontalAlignment="Center"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,10"/>
                
                <!-- Левая часть - информация о товаре -->
                <Grid RowDefinitions="*,*" Margin="0,30,0,0">
                    
                    <!-- Картинка товара в карточке -->
                    <Border CornerRadius="8"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Margin="15,0,15,10"
                            ClipToBounds="True"
                            Background="White">
                        <Image Source="{Binding CurrentProductDetails.DisplayImage}"
                               Stretch="UniformToFill"/>
                    </Border>
                    
                    <!-- Информация о товаре в карточке -->
                    <Border Grid.Row="1"
                            CornerRadius="8"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Background="#F8F9FA"
                            Margin="15,0,15,15"
                            Padding="15">
                        <Grid RowDefinitions="*,*,*,*,*,*,Auto"
                              ColumnDefinitions="Auto,*"
                              Margin="5">
                            
                            <TextBlock Text="Название:"/>
                            <TextBlock Grid.Row="1" Text="Категория:" Margin="0 0 10 0"/>
                            <TextBlock Grid.Row="2" Text="Производитель:" Margin="0 0 10 0"/>
                            <TextBlock Grid.Row="3" Text="Страна:" Margin="0 0 10 0"/>
                            <TextBlock Grid.Row="4" Text="Описание:" Margin="0 0 10 0"/>
                            <TextBlock Grid.Row="5" FontWeight="SemiBold" Text="Цена:" Margin="0 0 10 0"/>
                            
                            <Grid Grid.Column="1">
                                <TextBox BorderThickness="0"
                                         Padding="5 0"
                                         IsVisible="{Binding IsEditing}"
                                         Text="{Binding CurrentProductDetails.Name}"/>
                                
                                <TextBlock IsVisible="{Binding !IsEditing}"
                                            Text="{Binding CurrentProductDetails.Name}"/>
                            </Grid>
                            
                            <Grid Grid.Row="1" Grid.Column="1">
                                <TextBox BorderThickness="0"
                                         Padding="5 0"
                                         IsVisible="{Binding IsEditing}"
                                         Text="{Binding CurrentProductDetails.Category}"/>
                                
                                <TextBlock IsVisible="{Binding !IsEditing}"
                                           Text="{Binding CurrentProductDetails.Category}"/>
                            </Grid>
                            
                            <Grid Grid.Row="2" Grid.Column="1">
                                <TextBox BorderThickness="0"
                                         Padding="5 0"
                                         IsVisible="{Binding IsEditing}"
                                         Text="{Binding CurrentProductDetails.Producer}"/>
                                
                                <TextBlock IsVisible="{Binding !IsEditing}"
                                           Text="{Binding CurrentProductDetails.Producer}"/>
                            </Grid>
                            
                            <Grid Grid.Row="3" Grid.Column="1">
                                <TextBox BorderThickness="0"
                                         Padding="5 0"
                                         IsVisible="{Binding IsEditing}"
                                         Text="{Binding CurrentProductDetails.Country}"/>
                                
                                <TextBlock IsVisible="{Binding !IsEditing}"
                                           Text="{Binding CurrentProductDetails.Country}"/>
                            </Grid>
                            
                            <Grid Grid.Row="4" Grid.Column="1">
                                <TextBox BorderThickness="0"
                                         Padding="5 0"
                                         IsVisible="{Binding IsEditing}"
                                         Text="{Binding CurrentProductDetails.Description}"/>
                                
                                <TextBlock IsVisible="{Binding !IsEditing}"
                                           Text="{Binding CurrentProductDetails.Description}"/>
                            </Grid>
                            <TextBlock FontWeight="SemiBold" Grid.Column="1" Grid.Row="5">
                                <TextBlock Text="{Binding CurrentProductDetails.Price}"
                                         IsVisible="{Binding !IsEditing}"/>
                                
                                <TextBox Text="{Binding CurrentProductDetails.Price}"
                                         BorderThickness="0"
                                         Padding="5 0"
                                         IsVisible="{Binding IsEditing}"/>
                                <TextBlock Text="₽"/>
                            </TextBlock>
                            
                            <StackPanel Orientation="Horizontal"
                                        Grid.Row="6"
                                        Grid.ColumnSpan="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,5"
                                        Spacing="20">
                                <Button Content="Вернуться"
                                        Command="{Binding GoToCatalogCommand}"/>
                                
                                <Grid IsVisible="{Binding CanEdit}">
                                    <Button Content="{Binding SaveButtonText}"
                                            IsVisible="{Binding IsEditing}"
                                            Command="{Binding EndEditCommand}"/>
                                    <Button Content="Изменить"
                                            IsVisible="{Binding !IsEditing}"
                                            Command="{Binding BeginEditCommand}"/>
                                </Grid>
                            </StackPanel>
                            
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- Правая часть - параметры в карточке -->
                <Border Grid.Column="1" 
                        CornerRadius="8"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Background="#F8F9FA"
                        Margin="10,30,15,15">
                    <Grid>
                        <ScrollViewer Margin="10">
                            <ListBox ItemsSource="{Binding CurrentProductDetails.Parameters}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" 
                                                Background="Transparent"
                                                BorderBrush="#E0E0E0"
                                                BorderThickness="0,0,0,1"
                                                Margin="0,2">
                                            <Grid>
                                                
                                                <TextBlock IsVisible="{Binding !#RootControl.DataContext.IsEditing}">
                                                    <Run Text="{Binding Name}" FontWeight="SemiBold"/>
                                                    <Run Text=": "/>
                                                    <Run Text="{Binding Value}"/>
                                                    <Run Text="{Binding Unit}"/>
                                                </TextBlock>
                                                
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="1"
                                                            IsVisible="{Binding #RootControl.DataContext.IsEditing}">
                                                    <TextBox Text="{Binding Name}"
                                                             BorderThickness="0"/>
                                                    <TextBox Text="{Binding Value}"
                                                             BorderThickness="0"/>
                                                    <TextBox Text="{Binding Unit}"
                                                             BorderThickness="0"/>
                                                </StackPanel>
                                                
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>
                
            </Grid>
        </Border>
    </Grid>
    
</UserControl>
